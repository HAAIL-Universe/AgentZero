# NEVER commit to git — will blow LFS budget instantly.
models/
*.safetensors
*.bin
*.gguf
*.ggml
*.pt
*.pth
*.ckpt
*.pkl
*.h5
*.npy
*.npz
*.onnx
training/.notified
training/checkpoints/
training/runs/

